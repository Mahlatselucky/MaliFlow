<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="16dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Category Emoji -->
        <TextView
            android:id="@+id/tvCategoryEmoji"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:textSize="24sp"
            android:gravity="center"
            android:layout_marginEnd="12dp"
            android:background="@drawable/circle_white"
            android:elevation="2dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCategoryName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/dark_grey"/>

            <TextView
                android:id="@+id/tvCategoryLimit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/navy"
                android:layout_marginTop="2dp"
                android:alpha="0.7"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnEditLimit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/navy"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/edit_limit" />

        <ImageButton
            android:id="@+id/btnDeleteCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/error_red"
            android:contentDescription="@string/delete_category" />
    </LinearLayout>

    <!-- Budget Rollover Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/rollover_description"
            android:textSize="12sp"
            android:textColor="@color/navy"
            android:alpha="0.7"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchRollover"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

</LinearLayout>
